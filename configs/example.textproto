# Example VADConfig — pass via `./bin/vad -config configs/example.textproto`.
# Schema: proto/vad.proto's VADConfig message.

# Which backend to load at startup.
#   VAD_MODEL_PYANNOTE   — full diarization (3 speakers max)
#   VAD_MODEL_FSMN       — tiny, VAD-only, Chinese-trained
#   VAD_MODEL_FIRERED    — small, VAD-only, EN-friendly
#   VAD_MODEL_MARBLENET  — TODO: multilingual NVIDIA
#   VAD_MODEL_SILERO     — TODO: tiny well-known VAD
model: VAD_MODEL_FIRERED

# Optional. Per-model defaults are applied if unset:
#   pyannote   → weights/model.onnx
#   fsmn       → weights/fsmn-vad
#   firered    → weights/firered-vad
#   marblenet  → weights/marblenet
#   silero     → weights/silero
# weights_dir: "weights/firered-vad"

# gRPC port; defaults to 50051 if 0/unset.
port: 50051

# ONNX Runtime shared library path. If empty, falls back to $ONNXRUNTIME_LIB.
# onnxruntime_lib: "third_party/onnxruntime-osx-arm64-1.22.0/lib/libonnxruntime.dylib"

# Pyannote-only: URL the Fetch RPC redirects clients to (e.g. for
# transformers.js to grab the weights without round-tripping through this
# server). Ignored for other backends.
# weights_url: "https://huggingface.co/onnx-community/pyannote-segmentation-3.0/resolve/main/onnx/model.onnx"
